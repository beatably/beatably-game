.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Local development
.vercel

# iOS / Xcode
# The .xcodeproj is generated by xcodegen from project.yml — regenerate with
# `cd ios && xcodegen generate`. Source + project.yml are the tracked truth.
ios/Beatably.xcodeproj/
ios/build/
ios/DerivedData/
DerivedData/
